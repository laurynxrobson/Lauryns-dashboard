# ── Stitch Open Finance (South African banks) ────────────────────────────────
# Sign up at https://stitch.money/developers (free sandbox tier)
# Supported banks: Investec, Discovery Bank, Capitec, FNB, Standard Bank,
#                  Nedbank, Absa, TymeBank, African Bank
#
# After creating an app in the Stitch console you'll receive a client_id
# and client_secret. Add your redirect URI in the Stitch dashboard settings:
#   http://localhost:5173/finance  (web dev)
STITCH_CLIENT_ID=your_stitch_client_id
STITCH_CLIENT_SECRET=your_stitch_client_secret
# Must match a URI registered in your Stitch app settings
STITCH_REDIRECT_URI=http://localhost:5173/finance

# ── Anthropic ────────────────────────────────────────────────────────────────
# Sign up at https://console.anthropic.com
# AI Advisor uses Claude Opus 4.6 with adaptive thinking
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
# Web app origin (for CORS)
CLIENT_ORIGIN=http://localhost:5173
